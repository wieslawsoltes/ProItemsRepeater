<UserControl
    x:Class="ItemsRepeaterUnoSample.RepeaterDataGridPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:data="using:Avalonia.Controls.DataGrid">
    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock Text="RepeaterDataGrid with SelectingItemsRepeater rows." />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Randomize Heights" Click="RandomizeHeightsClick" />
                <TextBlock Text="Row and cell selection supported." VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <data:RepeaterDataGrid x:Name="grid"
                               Grid.Row="1"
                               AutoMeasureRowLimit="200"
                               ItemsSource="{Binding Items}"
                               RowHeightBindingPath="Height"
                               SelectionMode="Multiple">
            <data:RepeaterDataGrid.Columns>
                <data:RepeaterDataGridColumn Header="#" MinWidth="70" BindingPath="Id" />
                <data:RepeaterDataGridColumn Header="Name" BindingPath="Name" />
                <data:RepeaterDataGridColumn Header="Category" BindingPath="Category" />
                <data:RepeaterDataGridColumn Header="Price" BindingPath="Price" />
                <data:RepeaterDataGridColumn Header="Stock" BindingPath="Stock" />
            </data:RepeaterDataGrid.Columns>
        </data:RepeaterDataGrid>
    </Grid>
</UserControl>
