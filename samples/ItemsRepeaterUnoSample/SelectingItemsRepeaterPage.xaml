<UserControl
    x:Class="ItemsRepeaterUnoSample.SelectingItemsRepeaterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Avalonia.Controls"
    xmlns:layout="using:Avalonia.Layout"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls">
    <UserControl.Resources>
        <DataTemplate x:Key="SelectionItemTemplate">
            <Border Background="#FDE68A"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    Height="{Binding Height}"
                    Width="{Binding Width}"
                    Padding="8">
                <TextBlock HorizontalAlignment="Center" Text="{Binding Text}" />
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock Text="SelectingItemsRepeater adds selection support on top of ItemsRepeater."
                       TextWrapping="WrapWholeWords" />
            <TextBlock Text="Click items to toggle selection. Shift selects a range."
                       TextWrapping="WrapWholeWords" />
            <ComboBox x:Name="layoutCombo" SelectedIndex="0" SelectionChanged="LayoutChanged">
                <x:String>Stack - Vertical</x:String>
                <x:String>Stack - Horizontal</x:String>
                <x:String>NonVirtualizingStack - Vertical</x:String>
                <x:String>NonVirtualizingStack - Horizontal</x:String>
                <x:String>UniformGrid - Vertical</x:String>
                <x:String>UniformGrid - Horizontal</x:String>
                <x:String>Wrap - Vertical</x:String>
                <x:String>Wrap - Horizontal</x:String>
            </ComboBox>
            <Button Content="Add Item" Click="AddItemClick" />
            <Button Content="Remove Item" Click="RemoveItemClick" />
            <Button Content="Randomize Heights" Click="RandomizeHeightsClick" />
            <Button Content="Randomize Widths" Click="RandomizeWidthsClick" />
            <Button Content="Reset Items" Click="ResetItemsClick" />
            <Button Content="Scroll to Last" Click="ScrollToLastClick" />
            <Button Content="Scroll to Random" Click="ScrollToRandomClick" />
            <Button Content="Scroll to Selected" Click="ScrollToSelectedClick" />
        </StackPanel>

        <Border Grid.Column="0" BorderBrush="#FFD9D9D9" BorderThickness="1">
            <mux:ItemsRepeaterScrollHost>
                <ScrollViewer x:Name="scroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <controls:SelectingItemsRepeater x:Name="selectingRepeater"
                                                     ItemTemplate="{StaticResource SelectionItemTemplate}"
                                                     ItemsSource="{Binding Items}"
                                                     SelectionMode="Multiple" />
                </ScrollViewer>
            </mux:ItemsRepeaterScrollHost>
        </Border>
    </Grid>
</UserControl>
